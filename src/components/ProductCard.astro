---
interface Props {
  title: string;
  category: string;
  price: string;
  ctaLabel: string;
}

const { title, category, price, ctaLabel } = Astro.props;
---
<article
  class="flex flex-col overflow-hidden rounded-2xl border border-slate-100 bg-white shadow-sm shadow-slate-100 transition hover:-translate-y-0.5 hover:shadow-md"
>
  <div class="relative aspect-4/3 bg-slate-100">
    <div
      class="absolute inset-4 rounded-2xl bg-linear-to-br from-fuchsia-100 via-rose-100 to-amber-100"
    />
  </div>
  <div class="flex flex-1 flex-col gap-2 px-4 py-3">
    <p class="text-[11px] font-medium uppercase tracking-[0.16em] text-slate-500">
      {category}
    </p>
    <h3 class="line-clamp-2 text-sm font-medium text-slate-900">
      {title}
    </h3>
    <div class="mt-1 flex items-center justify-between text-sm">
      <span class="font-semibold text-slate-900">{price}</span>
    </div>
    <div class="mt-3">
      <button
        type="button"
        class="inline-flex w-full items-center justify-center rounded-full bg-slate-900 px-3 py-1.5 text-xs font-medium text-white transition hover:bg-slate-800"
      >
        {ctaLabel}
      </button>
    </div>
  </div>
</article>

