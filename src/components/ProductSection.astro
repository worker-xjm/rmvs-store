---
import SectionHeader from "./SectionHeader.astro";
import ProductCard from "./ProductCard.astro";

interface Product {
  id: string | number;
  title: string;
  category: string;
  price: string;
  ctaLabel: string;
}

interface Props {
  sectionId?: string;
  title: string;
  products: Product[];
}

const { sectionId, title, products } = Astro.props;
---
<section
  id={sectionId}
  class="border-b border-slate-100 bg-white/40"
>
  <div class="mx-auto max-w-6xl px-4 py-8 md:px-6 lg:px-8 lg:py-10">
    <SectionHeader id={sectionId} title={title} />
    <div
      class="grid grid-cols-1 gap-4 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4"
    >
      {
        products.map((product) => (
          <ProductCard {...product} />
        ))
      }
    </div>
  </div>
</section>

