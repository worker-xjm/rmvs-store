---
import "./header.css";
const navItems = [
  { href: "/", label: "HOME" },
  { href: "/about-us", label: "About us" },
  { href: "/contact-us", label: "Contact us" },
  { href: "/shop-now", label: "Shop Now" },
];
const user = await Astro.session?.get("user");
import personSvg from "../assets/person.svg?raw";
---
<header
  id="header"
  class="sticky top-0 z-40 h-22 text-white shadow-md"
>
  <div
    class="mx-auto flex max-w-6xl items-center justify-between px-4 py-3 md:px-6 lg:px-8 h-full"
  >
    <a href="/" class="text-lg font-semibold tracking-tight">
      RMVS Market
    </a>
    <nav
      class="flex items-center gap-6 text-sm font-medium md:gap-8"
    >
      <span class="hidden md:flex md:items-center md:gap-6">
        {
          navItems.map((item) => (
            <a
              href={item.href}
              class="transition-colors hover:text-pink-100 text-pink-50/80"
            >
              {item.label}
            </a>
          ))
        }
      </span>
      {
        user ? (
          <span class="flex items-center gap-3">
            {user.picture && (
              <img
                src={user.picture}
                alt="user profile picture"
                width={28}
                height={28}
                class="rounded-full"
              />
            )}
            <span class="max-w-24 truncate text-pink-50/90 md:max-w-none">
              {user.name || user.email}
            </span>
            <a
              href="/api/auth/logout"
              class="rounded px-2 py-1 transition-colors hover:bg-white/20 text-pink-50/80"
            >
              登出
            </a>
          </span>
        ) : (
          <a
            href="/api/auth/google"
            class="rounded bg-white/20  size-8 flex items-center justify-center  font-medium transition-colors hover:bg-white/30 text-pink-50"
          >
            <span class="inline-flex size-6 [&>svg]:size-full [&>svg]:currentColor" set:html={personSvg} />
            {/* <img src="/person.svg" alt="person" class="size-6"  /> */}
            {/* <img src="/google.svg" alt="Google" width={20} height={20} /> */}
          </a>
        )
      }
    </nav>
  </div>
</header>
