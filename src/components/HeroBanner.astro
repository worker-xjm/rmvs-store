---
const title = "RMVS Market | Women’s Fashion";
const subtitle =
  "Timeless elegance meets modern style — premium womenswear for every occasion.";
---
<section
  id="home"
  class="border-b border-slate-200 bg-linear-to-br from-fuchsia-50 via-white to-sky-50"
>
  <div
    class="mx-auto grid max-w-6xl items-center gap-10 px-4 py-10 md:grid-cols-2 md:px-6 md:py-16 lg:px-8 lg:py-20"
  >
    <div class="space-y-6">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-fuchsia-600">
        RMVS Market
      </p>
      <h1 class="text-3xl font-semibold tracking-tight text-slate-900 sm:text-4xl lg:text-5xl">
        {title}
      </h1>
      <p class="max-w-xl text-sm text-slate-600 sm:text-base">
        {subtitle}
      </p>
      <div class="flex flex-wrap items-center gap-4">
        <a
          href="#shop"
          class="inline-flex items-center justify-center rounded-full bg-fuchsia-600 px-6 py-2.5 text-sm font-medium text-white shadow-sm transition hover:bg-fuchsia-700"
        >
          Shop Now
        </a>
        <a
          href="#best-sellers"
          class="inline-flex items-center text-sm font-medium text-fuchsia-700 hover:text-fuchsia-800"
        >
          Best Sellers
          <span class="ml-1 text-base">›</span>
        </a>
      </div>
    </div>
    <div
      class="relative h-52 rounded-3xl bg-linear-to-br from-fuchsia-500 via-rose-400 to-amber-300 shadow-lg shadow-fuchsia-200 sm:h-64 md:h-72"
    >
      <div
        class="pointer-events-none absolute inset-6 rounded-3xl border border-white/40 bg-white/10 backdrop-blur-sm"
      />
    </div>
  </div>
</section>

