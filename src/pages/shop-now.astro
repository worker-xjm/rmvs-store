---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import type { Product } from "../data/products";
import { allProducts } from "../data/products";
const products: Product[] = allProducts;
---

<Layout>
  <Header />

  <section class="bg-white">
    <div
      class="mx-auto max-w-6xl px-4 py-10 md:px-6 lg:px-8 lg:py-14"
    >
      <header class="mb-8 space-y-3 text-center md:mb-10">
        <p
          class="text-xs font-semibold uppercase tracking-[0.2em] text-fuchsia-600"
        >
          Shop Now
        </p>
        <h1
          class="text-2xl font-semibold tracking-tight text-slate-900 sm:text-3xl"
        >
          Complete your look with RMVS Market accessories.
        </h1>
        <p class="mx-auto max-w-2xl text-sm leading-relaxed text-slate-600">
          Elegant, minimal, and fashion-forward pieces that add the finishing
          touch to your personal style.
        </p>
      </header>

      <div
        class="grid grid-cols-1 gap-4 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4"
      >
        {
          products.map((product) => (
            <article
              class="flex flex-col justify-between rounded-2xl border border-slate-200 bg-white p-4 text-sm shadow-sm shadow-slate-100 transition hover:-translate-y-0.5 hover:shadow-md md:p-5"
            >
              <div class="space-y-1.5">
                <p class="text-[11px] font-medium uppercase tracking-[0.18em] text-slate-500">
                  {product.category}
                </p>
                <h2 class="text-xs font-semibold text-slate-900 sm:text-sm">
                  {product.title}
                </h2>
              </div>

              <div class="mt-4 flex items-center justify-between">
                <p class="text-sm font-semibold text-slate-900">
                  {product.price}
                </p>
                <a
                  href="#"
                  class="inline-flex items-center rounded-full border border-slate-900/10 bg-slate-900 text-[11px] font-medium text-white px-3 py-1.5 transition hover:bg-fuchsia-700"
                >
                  {product.ctaLabel}
                </a>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <Footer />
</Layout>

